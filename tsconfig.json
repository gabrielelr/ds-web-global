{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "ignoreDeprecations": "6.0",
    "allowJs": false,
    "checkJs": false
  },
  "include": [
    "src/lib/Button/Button.tsx",
    "src/lib/ButtonIcon/ButtonIcon.tsx",
    "src/lib/Link/Link.tsx",
    "src/lib/PageControlItem/PageControlItem.tsx",
    "src/lib/PageControl/PageControl.tsx",
    "src/lib/SearchBar/SearchBar.tsx",
    "src/lib/BadgeStatus/BadgeStatus.tsx",
    "src/lib/Heading/Heading.tsx",
    "src/lib/react.ts"
  ]
}
